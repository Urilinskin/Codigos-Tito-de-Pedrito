body {
font-family: ‘Syne’, sans-serif;
background: var(–bg);
color: var(–text);
min-height: 100vh;
padding: 0;
overflow-x: hidden;
}

/* HEADER */
header {
padding: 40px 48px 32px;
border-bottom: 1px solid var(–border);
display: flex;
align-items: flex-end;
gap: 24px;
position: relative;
overflow: hidden;
}
header::before {
content: ‘’;
position: absolute;
top: -60px; right: -60px;
width: 300px; height: 300px;
background: radial-gradient(circle, rgba(212,240,96,0.12) 0%, transparent 70%);
pointer-events: none;
}
.logo-mark {
width: 56px; height: 56px;
background: var(–accent);
border-radius: 12px;
display: grid;
place-items: center;
font-size: 28px;
flex-shrink: 0;
}
header h1 {
font-size: clamp(28px, 4vw, 42px);
font-weight: 800;
letter-spacing: -1px;
line-height: 1;
}
header h1 span { color: var(–accent); }
.header-meta {
margin-left: auto;
text-align: right;
}
.header-meta .count {
font-size: 36px;
font-weight: 800;
color: var(–accent);
line-height: 1;
font-family: ‘DM Mono’, monospace;
}
.header-meta .label { font-size: 12px; color: var(–muted); letter-spacing: 2px; text-transform: uppercase; }

/* FILTERS */
.filters-wrap {
padding: 24px 48px;
border-bottom: 1px solid var(–border);
background: var(–surface);
position: sticky;
top: 0;
z-index: 100;
}
.filters-label {
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 12px;
}
.filters {
display: flex;
flex-wrap: wrap;
gap: 8px;
}
.filter-btn {
padding: 8px 16px;
border-radius: 100px;
border: 1.5px solid var(–border);
background: transparent;
color: var(–muted);
font-family: ‘Syne’, sans-serif;
font-size: 13px;
font-weight: 600;
cursor: pointer;
transition: all 0.18s ease;
display: flex;
align-items: center;
gap: 7px;
user-select: none;
white-space: nowrap;
}
.filter-btn .dot {
width: 8px; height: 8px;
border-radius: 50%;
flex-shrink: 0;
}
.filter-btn:hover {
border-color: var(–text);
color: var(–text);
transform: translateY(-1px);
}
.filter-btn.active {
background: var(–cat-color, var(–accent));
border-color: var(–cat-color, var(–accent));
color: #0f0f0d;
}
.filter-btn .badge {
background: rgba(0,0,0,0.15);
border-radius: 100px;
padding: 1px 7px;
font-size: 11px;
font-family: ‘DM Mono’, monospace;
}
.filter-btn.active .badge { background: rgba(0,0,0,0.2); }

/* SEARCH */
.search-wrap { padding: 20px 48px 0; display: flex; gap: 12px; align-items: center; }
.search-input {
flex: 1;
max-width: 360px;
padding: 10px 16px 10px 40px;
background: var(–surface2);
border: 1.5px solid var(–border);
border-radius: 10px;
color: var(–text);
font-family: ‘DM Mono’, monospace;
font-size: 13px;
outline: none;
transition: border-color 0.2s;
position: relative;
}
.search-wrap .icon { position: relative; }
.search-wrap .icon svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); opacity: 0.4; pointer-events: none; }
.search-input:focus { border-color: var(–accent); }
.result-info {
font-size: 12px;
color: var(–muted);
font-family: ‘DM Mono’, monospace;
margin-left: auto;
}
.result-info span { color: var(–accent); font-weight: 500; }

/* GRID */
.grid-wrap { padding: 28px 48px 60px; }
.grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
gap: 12px;
}

/* CARD */
.card {
background: var(–surface);
border: 1.5px solid var(–border);
border-radius: 14px;
padding: 16px 18px;
cursor: default;
transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
position: relative;
overflow: hidden;
display: flex;
flex-direction: column;
gap: 10px;
animation: fadeIn 0.3s ease forwards;
}
.card::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 3px;
background: var(–cat-color, var(–muted));
opacity: 0.7;
}
.card:hover {
transform: translateY(-3px);
border-color: var(–cat-color, var(–border));
box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 0 1px var(–cat-color, transparent);
}
.card-code {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: var(–muted);
letter-spacing: 1px;
}
.card-name {
font-size: 15px;
font-weight: 700;
line-height: 1.3;
color: var(–text);
letter-spacing: -0.2px;
}
.card-cat {
display: inline-flex;
align-items: center;
gap: 5px;
padding: 3px 10px;
border-radius: 100px;
font-size: 11px;
font-weight: 600;
letter-spacing: 0.5px;
background: color-mix(in srgb, var(–cat-color, var(–muted)) 15%, transparent);
color: var(–cat-color, var(–muted));
align-self: flex-start;
}
.card-cat .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

.hidden { display: none !important; }

@keyframes fadeIn {
from { opacity: 0; transform: translateY(6px); }
to { opacity: 1; transform: translateY(0); }
}

/* EMPTY STATE */
.empty {
grid-column: 1/-1;
text-align: center;
padding: 80px 20px;
color: var(–muted);
}
.empty .big { font-size: 48px; margin-bottom: 12px; }
.empty p { font-size: 15px; }

@media (max-width: 640px) {
header, .filters-wrap, .search-wrap, .grid-wrap { padding-left: 20px; padding-right: 20px; }
.grid { grid-template-columns: 1fr 1fr; gap: 8px; }
}
</style>

